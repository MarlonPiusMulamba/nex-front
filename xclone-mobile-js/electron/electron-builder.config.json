{
  "includeSubNodeModules": false,
  "npmRebuild": false,
  "appId": "com.nexfi.app",
  "productName": "NexFi",
  "directories": {
    "buildResources": "resources"
  },
  "files": [
    "assets/**/*",
    "build/**/*",
    "capacitor.config.*",
    "app/**/*"
  ],
  "nsis": {
    "allowElevation": true,
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "assets/appIcon.ico"
  },
  "publish": {
    "provider": "generic",
    "url": "http://127.0.0.1"
  },
  "electronDownload": {
    "cache": "./electron-cache"
  },
  "mac": {
    "category": "your.app.category.type",
    "target": "dmg"
  }
}